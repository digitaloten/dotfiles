[user]
	name = pekora
	email = pekora@usada.io
	signingkey = pekora@usada.io
[color]
	ui = true
[core]
	excludesfile = ~/.gitignore
[pull]
	rebase = false
[commit]
	gpgsign = true
[push]
	autoSetupRemote = true
[fetch]
	prune = true
[diff "gpg"]
	textconv = gpg --decrypt --quiet --batch
[init]
	defaultBranch = main
